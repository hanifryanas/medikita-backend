PORT=YOUR_PORT
APP_NAME=YOUR_APP_NAME
APP_URL=YOUR_APP_URL

# --- Database ---
# Option A (recommended for prod / Neon / Render / any managed Postgres):
# Set DATABASE_URL and SSL will be enabled automatically.
# Example: postgresql://user:password@ep-xxx.neon.tech/medikita?sslmode=require
DATABASE_URL=

# Option B (local dev with the discrete fields below — leave DATABASE_URL empty):
DB_HOST=YOUR_HOST
DB_PORT=YOUR_PORT
DB_DATABASE=YOUR_DATABASE
DB_USERNAME=YOUR_USERNAME
DB_PASSWORD=YOUR_PASSWORD
# Force SSL on the discrete connection (optional; auto-on when DATABASE_URL is set):
# DB_SSL=true

ACCESS_TOKEN_SECRET=YOUR_ACCESS_TOKEN_SECRET
ACCESS_TOKEN_EXPIRATION_HOUR=YOUR_ACCESS_TOKEN_EXPIRATION_HOUR
REFRESH_TOKEN_SECRET=YOUR_REFRESH_TOKEN_SECRET
REFRESH_TOKEN_EXPIRATION_HOUR=YOUR_REFRESH_TOKEN_EXPIRATION_HOUR

CORS_ORIGINS=YOUR_CORS_ORIGINS